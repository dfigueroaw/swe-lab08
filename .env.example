# Configuracion compartida por Docker Compose y ejecucion local.
# Copie este archivo como .env y reemplace los valores necesarios.

RABBITMQ_URL=amqp://<usuario>:<contrasena>@<host>:<puerto>/<virtual_host_codificado>
RABBITMQ_EXCHANGE=rewards.exchange
TRANSACTION_QUEUE=transaction.created.queue

RESTAURANT_PORT=3000
TRANSACTIONS_DB_NAME=transactions
TRANSACTIONS_DB_USER=transactions
TRANSACTIONS_DB_PASSWORD=transactions
TRANSACTIONS_DB_HOST=transactions-db
TRANSACTIONS_DB_PORT=5432

REWARDS_PORT=3001
REWARDS_DB_NAME=rewards
REWARDS_DB_USER=rewards
REWARDS_DB_PASSWORD=rewards
REWARDS_DB_HOST=rewards-db
REWARDS_DB_PORT=5433

DB_SYNCHRONIZE=false
